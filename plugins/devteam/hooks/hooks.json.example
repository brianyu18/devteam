{
  "_comment": "devteam hooks — SessionStart surfaces project status + checkpoint suggestion; Stop runs checkpoint-autosave (change-based) and checkpoint-reminder (commit nag); SessionEnd runs checkpoint-autosave as the final backstop. Activated via /lead-setup which writes these entries to ~/.claude/settings.json. Rename to hooks.json to enable plugin-local activation (rarely needed; settings-level registration is the standard path).",
  "SessionStart": [
    { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh" }
  ],
  "Stop": [
    { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/checkpoint-autosave.sh" },
    { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/checkpoint-reminder.sh", "timeout": 5 }
  ],
  "SessionEnd": [
    { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/checkpoint-autosave.sh" }
  ]
}
